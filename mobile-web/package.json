{
  "name": "mobile-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pwa": "vite build",
    "build:apk:web": "cross-env CAPACITOR_BUILD=true vite build",
    "cap:sync": "npm run build:apk:web && npx cap sync android",
    "cap:open": "npx cap open android",
    "apk:debug": "npm run cap:sync && cd android && gradlew.bat assembleDebug && node ..\\scripts\\publish-apk.mjs",
    "apk:release": "npm run cap:sync && cd android && gradlew.bat assembleRelease -x lint -x lintVitalAnalyzeRelease && node ..\\scripts\\publish-release-apk.mjs",
    "apk:publish": "npm run apk:debug",
    "apk:publish:release": "npm run apk:release",
    "apk:watch": "node scripts/watch-apk-build.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "cross-env ELECTRON_BUILD=true vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@ericblade/quagga2": "^1.12.1",
    "@heroicons/react": "^2.2.0",
    "axios": "^1.13.3",
    "html5-qrcode": "^2.3.8",
    "install": "^0.13.0",
    "jsqr": "^1.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.srilakshmitextiles.mobile",
    "productName": "Loom Track Mobile",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "icon.png",
      "icon.ico",
      "package.json"
    ],
    "directories": {
      "output": "setup_release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Loom Track Mobile",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}"
    }
  }
}
