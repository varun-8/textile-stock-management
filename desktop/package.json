{
  "name": "desktop",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "vite build && electron-builder --win --x64"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "html5-qrcode": "^2.3.8",
    "install": "^0.13.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fs-extra": "^11.3.4",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5",
    "vite": "^5.0.0",
    "wait-on": "^9.0.3"
  },
  "main": "electron-main.cjs",
  "build": {
    "appId": "com.textilestock.inventory",
    "productName": "Textile Stock Management",
    "directories": {
      "output": "dist-app",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "electron-main.cjs",
      "preload.cjs",
      "public/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "resources/mongo/**/*",
      "resources/backend/**/*",
      "resources/node/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Textile Stock Management"
    },
    "portable": {
      "artifactName": "Textile-Stock-Management-Portable.exe"
    }
  }
}
