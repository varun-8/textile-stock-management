# Environment Variables Template (For Packaged Electron App)
# Copy this file to .env and fill in your values
# NEVER commit .env to git (only this template)

# This .env is for the packaged desktop application
# Keep it synchronized with backend/.env

# === Company/Workspace Configuration ===
WORKSPACE_CODE=default

# === Database ===
MONGODB_URI=mongodb://127.0.0.1:27017/textile-stock-management

# === Ports ===
HTTP_PORT=5050
HTTPS_PORT=5051

# === Security ===
NODE_ENV=production
APP_PASSWORD=your-secure-admin-password-here
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
SYSTEM_WIPE_PASSWORD=your-system-wipe-password-here

# === TLS/HTTPS Certificates ===
TLS_KEY_PATH=./stock-system.local-key.pem
TLS_CERT_PATH=./stock-system.local.pem

# === Notes ===
# - Keep synchronized with ../../../backend/.env
# - This file is used when running the packaged Electron app
# - Generate unique JWT_SECRET and APP_PASSWORD
# - For production: NODE_ENV=production
