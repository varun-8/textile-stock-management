# Backend - Port Configuration
# NOTE: When running via Electron, these values are OVERRIDDEN with dynamic ports
# Electron assigns: HTTP_PORT=5050+ (incremented to avoid conflicts), PORT=5051+
# These values are used only when running the backend directly (node server.js)
HTTP_PORT=5000
PORT=5001

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/textile-stock-management

# Authentication
APP_USERNAME=admin
APP_PASSWORD=123
JWT_SECRET=textile-stock-jwt-secret-local-2026-production-key-v1-secure
ADMIN_TOKEN_TTL=24h
PAIRING_TOKEN_TTL=15m

# Security & TLS
ENABLE_HTTPS_COMPAT_443=true
SYSTEM_WIPE_PASSWORD=SystemWipeLocal@2026!Secure
TLS_KEY_PATH=./stock-system.local-key.pem
TLS_CERT_PATH=./stock-system.local.pem

# CORS Configuration
# Uses hostname-based discovery (survives IP changes)
CORS_ALLOWED_ORIGINS=https://localhost:5001,https://localhost:5051,https://localhost:443,https://stock-system.local:5001,https://stock-system.local:5051,https://stock-system.local:443,http://localhost:5000,http://localhost:5050,http://localhost:5173,http://localhost:5174,file://*

# License (disabled for now)
LICENSE_REQUIRED=false
LICENSE_DATA_DIR=./license-data
LICENSE_PUBLIC_KEY_PATH=./license-data/license-public.pem

# Network
# Use hostname instead of hardcoded IP (survives IP changes on same WiFi)
PUBLIC_PWA_HOST=stock-system.local
MDNS_ENABLED=true
MDNS_SERVICE_NAME=stock-system

# Environment
NODE_ENV=production
